# 复制为 .env 后按需修改；.env 不提交。

# PostgreSQL（业务 + 事件账本 + LangGraph checkpoint）
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_pwd
POSTGRES_DB=my_agent
POSTGRES_PORT=5432

# Qdrant（向量库）
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Redis
REDIS_PORT=6379

# MinIO（对象存储）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# NATS（事件总线）
NATS_PORT=4222

# ===== 以下由你填入真实密钥（认知面用，后续里程碑接入）=====
# LLM：优先 Claude + DeepSeek
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# 生图：国产便宜模型优先（如豆包/通义万相），或 OpenAI，可切换
IMAGE_GEN_PROVIDER=
IMAGE_GEN_API_KEY=

# ===== 工具生态：MCP / Skill =====
# MCP servers（JSON，认知面据此预热三传输 stdio/sse/streamable_http）。stdio 示例：
# COGNITION_MCP_SERVERS={"fetch":{"transport":"stdio","command":"uvx","args":["mcp-server-fetch"]}}
COGNITION_MCP_ENABLED=true
COGNITION_MCP_SERVERS={}
# Skill 目录（JSON 数组）：扫描其中每个 <skill>/SKILL.md（渐进式披露 + 脚本）
COGNITION_SKILLS_ENABLED=true
COGNITION_SKILLS_DIRS=["./cognition/examples/skills"]
# 脚本运行器：local（dev/CI，无隔离）| docker（生产隔离：--network none + ro 挂载 + 资源限制）
COGNITION_SKILL_RUNNER=local
COGNITION_SKILL_RUNNER_IMAGE=my-agent/skill-executor:latest

# ===== Agentic RAG（Qdrant 混合检索）=====
# 默认关；开启后 knowledge_search 工具注入外层图。测试用 fake，不需 key/服务。
COGNITION_RAG_ENABLED=false
# Qdrant：真实服务填 http://localhost:6333；":memory:" 或空 = 本地内存模式（离线/测试）
COGNITION_QDRANT_URL=http://localhost:6333
COGNITION_QDRANT_COLLECTION=cognition_docs
# embedding：fake（确定性测试）| fastembed（本地 ONNX，需 uv add fastembed，首用下模型）| siliconflow（国产便宜 API）
COGNITION_EMBEDDING_PROVIDER=fake
COGNITION_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
COGNITION_EMBEDDING_DIMENSION=64
COGNITION_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# sparse：fake（确定性 hashing）| fastembed（Qdrant/bm25）
COGNITION_SPARSE_PROVIDER=fake
# rerank：fake（词重叠）| siliconflow（bge-reranker-v2-m3）
COGNITION_RERANK_ENABLED=false
COGNITION_RERANK_PROVIDER=fake
COGNITION_RERANK_MODEL=BAAI/bge-reranker-v2-m3
COGNITION_RERANK_THRESHOLD=0.0
# embedding/rerank 若走 siliconflow 用此 key（DeepSeek 无 embedding，故独立）
SILICONFLOW_API_KEY=
# 检索/反思参数
COGNITION_RAG_TOP_K=10
COGNITION_RAG_RERANK_TOP_K=5
COGNITION_RAG_REFLECTION_LIMIT=2
COGNITION_RAG_SUBQUERY_MAX=3
