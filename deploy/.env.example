# 复制为 .env 后按需修改；.env 不提交。

# PostgreSQL（业务 + 事件账本 + LangGraph checkpoint）
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_pwd
POSTGRES_DB=my_agent
POSTGRES_PORT=5432

# Qdrant（向量库）
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Redis
REDIS_PORT=6379

# MinIO（对象存储）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# NATS（事件总线）
NATS_PORT=4222

# OTel 追踪（docs/18，默认关；profile "observability" 起 Tempo 才有意义）
# OTEL_ENABLED=1 时：Go 控制面建 agent.run 根 span + gRPC 传播 traceparent；认知面拦截器建
# server span（需镜像含 otel extra，见 deploy/observability/README.md）。两面直连 tempo:4317。
OTEL_ENABLED=false
TEMPO_HTTP_PORT=3200
TEMPO_OTLP_GRPC_PORT=4317
TEMPO_OTLP_HTTP_PORT=4318
# host 进程开发流（make control / make cognition）导出到宿主机上的 Tempo：
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ===== 以下由你填入真实密钥（认知面用，后续里程碑接入）=====
# LLM：优先 Claude + DeepSeek
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# 生图：国产便宜模型优先（如豆包/通义万相），或 OpenAI，可切换
# 生图 provider：openai(gpt-image-2，quality 默认 low 成本优先，用 OPENAI_API_KEY)
# | ark(火山方舟) | wanx(通义万相) | fake(测试)；空=不注册 image_generate 工具
IMAGE_GEN_PROVIDER=
IMAGE_GEN_API_KEY=

# ===== 本机应用进程连接 & 模型（`make cognition` / `make control` 会 source 本文件）=====
# 认知面 PG（LangGraph checkpointer=多轮记忆必需；注意认知面读 COGNITION_PG_DSN，不是 PG_DSN）
COGNITION_PG_DSN=postgres://agent:agent_pwd@localhost:55432/my_agent
# Go 控制面连接（Go 读 PG_DSN / COGNITION_ADDR / MINIO_ENDPOINT）
PG_DSN=postgres://agent:agent_pwd@localhost:55432/my_agent
COGNITION_ADDR=localhost:50051
MINIO_ENDPOINT=localhost:19000
# 认知面产物真实落 MinIO（write_report 等工具的报告可被 /artifacts 下载；默认关会导致下载 404）
COGNITION_MINIO_UPLOAD_ENABLED=true
# 认知面模型：COGNITION_FAKE_MODEL=1 无需 key 端到端；=0 走真实 provider。
COGNITION_FAKE_MODEL=1
COGNITION_MODEL_PROVIDER=deepseek
COGNITION_DEEPSEEK_MODEL=deepseek-chat
# COGNITION_PLANNER_PROVIDER=anthropic
# COGNITION_PLANNER_MODEL=claude-opus-4-8

# ===== 工具生态：MCP / Skill =====
# MCP servers（JSON，认知面据此预热三传输 stdio/sse/streamable_http）。stdio 示例：
# COGNITION_MCP_SERVERS={"fetch":{"transport":"stdio","command":"uvx","args":["mcp-server-fetch"]}}
COGNITION_MCP_ENABLED=true
# JSON 值用单引号包裹（Makefile source 本文件时保住内部双引号，否则 JSON 非法）
COGNITION_MCP_SERVERS='{}'
# Skill 目录（JSON 数组）：扫描其中每个 <skill>/SKILL.md（渐进式披露 + 脚本）
COGNITION_SKILLS_ENABLED=true
# 相对路径基准=认知面进程 CWD（make cognition 会 cd cognition/）——写 ./cognition/... 会静默零加载
COGNITION_SKILLS_DIRS='["./examples/skills", "./runtime/skills"]'
# 脚本运行器：local（dev/CI，无隔离）| docker（生产隔离：--network none + ro 挂载 + 资源限制）
COGNITION_SKILL_RUNNER=local
COGNITION_SKILL_RUNNER_IMAGE=my-agent/skill-executor:latest

# ===== Agentic RAG（Qdrant 混合检索）=====
# 默认关；开启后 knowledge_search 工具注入外层图。测试用 fake，不需 key/服务。
# M8 起默认开启：附件上传自动入 owner 知识库 + knowledge_search 检索（关掉则附件仅作对话上下文）
COGNITION_RAG_ENABLED=true
# Qdrant：真实服务填 http://localhost:6333；":memory:" 或空 = 本地内存模式（离线/测试）
COGNITION_QDRANT_URL=http://localhost:6333
COGNITION_QDRANT_COLLECTION=cognition_docs
# embedding：fake（确定性测试）| fastembed（本地 ONNX，需 uv add fastembed，首用下模型）| siliconflow（国产便宜 API）
COGNITION_EMBEDDING_PROVIDER=fastembed  # fastembed=本地零 key（首用下载模型）；siliconflow 需 key；fake 仅离线测试
COGNITION_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
COGNITION_EMBEDDING_DIMENSION=512  # 与 embedding 模型匹配（bge-small-zh-v1.5=512；bge-m3=1024）
COGNITION_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# sparse：fake（确定性 hashing）| fastembed（Qdrant/bm25）
COGNITION_SPARSE_PROVIDER=fastembed
# rerank：fake（词重叠）| siliconflow（bge-reranker-v2-m3）
COGNITION_RERANK_ENABLED=false
COGNITION_RERANK_PROVIDER=fake
COGNITION_RERANK_MODEL=BAAI/bge-reranker-v2-m3
COGNITION_RERANK_THRESHOLD=0.0
# embedding/rerank 若走 siliconflow 用此 key（DeepSeek 无 embedding，故独立）
SILICONFLOW_API_KEY=
# 检索/反思参数
COGNITION_RAG_TOP_K=10
COGNITION_RAG_RERANK_TOP_K=5
COGNITION_RAG_REFLECTION_LIMIT=2
COGNITION_RAG_SUBQUERY_MAX=3

# ===== host 进程 vs compose 容器的连接约定 =====
# 本文件（含 .env）里的 localhost DSN/端点只给 host 进程用（make cognition/control）。
# compose 起的业务服务（make stack-up）在 docker-compose.yml 的 environment 里
# 显式重钉为服务名端点（postgres:5432 / cognition:50051 / minio:9000 / qdrant:6333），
# 覆盖 env_file 值——两套并存，互不干扰。API 密钥仅经运行时 env_file 注入，
# .dockerignore 排除 deploy/.env，绝不进镜像层。

# ===== 联网搜索（web_search 工具）=====
# provider：auto（默认降级链：tavily(有 key 才入链)→bing→baidu→ddg，免 key 开箱可用）| tavily | bing | ddg | fake | 空=关闭
COGNITION_SEARCH_PROVIDER=auto
# Tavily（https://app.tavily.com 免费额度）；填上后 auto 自动切换
# COGNITION_TAVILY_API_KEY=tvly-xxxx
COGNITION_SEARCH_MAX_RESULTS=6
# ===== GitHub 深度调研认证（可选）=====
# 填后 web_fetch 仅对 api.github.com / raw.githubusercontent.com 注入 Authorization（60→5000 次/小时）
# COGNITION_GITHUB_TOKEN=ghp_xxxx
# ===== 深研/执行分支的工具调用硬预算 =====
# 每次图执行（react 主图 / 每个并行执行分支）最多工具调用次数，0=不限。达上限强制收口
# 作答（防执行器超量抓取拖满超时、烧穿搜索额度与模型余额；实测曾单 run 961 次 web_fetch）。
COGNITION_MAX_TOOL_CALLS_PER_BRANCH=40
# 单次 run 整体超时（秒，控制面）。深度研究多轮检索建议 ≥1200；默认 600。
RUN_TIMEOUT_S=1800
