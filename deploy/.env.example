# 复制为 .env 后按需修改；.env 不提交。

# PostgreSQL（业务 + 事件账本 + LangGraph checkpoint）
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_pwd
POSTGRES_DB=my_agent
POSTGRES_PORT=5432

# Qdrant（向量库）
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Redis
REDIS_PORT=6379

# MinIO（对象存储）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# NATS（事件总线）
NATS_PORT=4222

# ===== 以下由你填入真实密钥（认知面用，后续里程碑接入）=====
# LLM：优先 Claude + DeepSeek
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# 生图：国产便宜模型优先（如豆包/通义万相），或 OpenAI，可切换
IMAGE_GEN_PROVIDER=
IMAGE_GEN_API_KEY=
