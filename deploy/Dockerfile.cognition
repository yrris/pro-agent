# syntax=docker/dockerfile:1
# 认知面镜像。构建上下文 = 仓库根。genproto 不入库也不入上下文 → 镜像内用
# grpcio-tools 再生成（转写 Makefile 的 proto-py），构建期 import 冒烟即门禁。
FROM python:3.12-slim
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

WORKDIR /src/cognition
# 先装依赖层（锁文件不变则缓存命中）；[tool.uv] package=false → 只装依赖不装项目。
COPY cognition/pyproject.toml cognition/uv.lock ./
RUN uv sync --frozen --no-dev --extra skills

COPY cognition/ ./
COPY proto/ /src/proto/
# 生成 gRPC stub（等价 make proto-py：grpcio-tools 是主依赖，--no-dev 下可用）。
RUN mkdir -p cognition/genproto \
 && uv run python -m grpc_tools.protoc \
      -I /src/proto \
      --python_out=cognition/genproto \
      --grpc_python_out=cognition/genproto \
      --pyi_out=cognition/genproto \
      /src/proto/agent/v1/agent.proto \
 && find cognition/genproto -type d -exec touch {}/__init__.py \; \
 && uv run python -c "import cognition._genproto"

# 技能目录用镜像内绝对路径（宿主 .env 里的相对路径依赖 CWD，容器内不可靠）。
ENV COGNITION_SKILLS_DIRS='["/src/cognition/examples/skills", "/src/cognition/runtime/skills"]'
EXPOSE 50051
CMD ["uv", "run", "python", "-m", "cognition.server.grpc_server"]
