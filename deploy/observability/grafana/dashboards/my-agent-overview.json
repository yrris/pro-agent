        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(myagent_run_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "range": true,
          "refId": "C"
